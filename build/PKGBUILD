# https://gitlab.archlinux.org/archlinux/packaging/packages/emacs/-/blob/main/PKGBUILD

pkgname=emacs-git
pkgver=31.0.50
pkgrel=1
pkgdesc='GNU Emacs from git'
arch=('x86_64')
url="http://www.gnu.org/software/emacs/"
license=(GPL-3.0-or-later)
depends=(
    gmp
    gnutls
    lcms2
    libacl.so
    libasound.so
    libgccjit
    libdbus-1.so
    libfontconfig.so
    libfreetype.so
    libgdk-3.so
    libgdk_pixbuf-2.0.so
    libgif.so
    libgio-2.0.so
    libglib-2.0.so
    libgobject-2.0.so
    libgpm.so
    libgtk-3.so
    libharfbuzz.so
    libice
    libjpeg.so
    libncursesw.so
    libotf
    libpango-1.0.so
    libpng
    librsvg-2.so
    libsm
    sqlite libsqlite3.so
    libsystemd.so
    libtiff.so
    libtree-sitter.so
    libwebp.so
    libwebpdemux.so
    libxfixes
    libxml2.so
    m17n-lib
    zlib
    harfbuzz
    cairo
    jansson
    texinfo  # for makeinfo
)
makedepends=(git)
conflicts=(emacs emacs-nox emacs-wayland)
# source=("repo::git://git.savannah.gnu.org/emacs.git")
source=("repo::git+https://github.com/emacs-mirror/emacs.git")
options=(!strip)
b2sums=('SKIP')


prepare() {
    cd "$srcdir/repo"
    if [[ ! -x configure ]]; then
        ./autogen.sh git
        ./autogen.sh autoconf
    fi
}


build() {
    cd "$srcdir/repo"

    # gold linker
    #
    # TLDR; gold is around 2x times faster than GNU binutils linker. The
    # gold linker was designed as an ELF-specific linker unlink ld which
    # has support formats uses relies on heavy abstraction resulting more
    # memory and CPU resources.
    # export LD='/usr/bin/ld.gold'
    # export CFLAGS+=" -fuse-ld=gold"
    # export CXXFLAGS+=" -fuse-ld=gold"

    # fuse
    #
    # link-time optimization
    # export CFLAGS+=" -flto"
    # export CXXFLAGS+=" -flto"

    export ac_cv_lib_gif_EGifPutExtensionLast=yes

    CONF_ARGS=(
        --prefix=/usr
        --sysconfdir=/etc
        --libexecdir=/usr/lib
        --localstatedir=/var
        --mandir=/usr/share/man

        --disable-build-details
        --enable-link-time-optimization # LTO

        --with-modules
        --with-sound=alsa

        --with-json                     # default after 27.1, needs jansson
        --with-native-compilation=aot   # JIT yeah! needs libgccjit
        --with-tree-sitter
        --with-file-notification=yes

        # --with-pgtk                   # is not supported with X-windows
        --with-cairo                    # needs cairo
        --with-libsystemd
        --with-harfbuzz                 # default after 27.1
        --with-x-toolkit=gtk3           # {no, gtk3, lucid}
        --without-gconf                 # breaks set font from config
        --without-gsettings             # breaks set font from config

        # --with-xwidgets               # requires --with-x-toolkit=gtk3
        --without-compress-install
        --without-xaw3d
        --with-gameuser=no
    )
    ./configure "${CONF_ARGS[@]}"

    # https://wiki.archlinux.org/title/Makepkg#Parallel_compilation

    # min elisp modue pre-compile deferred for later
    # make -j$(nproc) NATIVE_FAST_BOOT=1

    # native compile ahead-of-time
    make -j$(nproc) NATIVE_FULL_AOT=1
}


package() {
    cd "$srcdir/repo"

    make DESTDIR="$pkgdir/" install

    # fix user/root permissions on usr/share files
    chown -R root:root "${pkgdir}/usr/share/emacs/${pkgver}"
}


# Local Variables:
# mode: shell-script
# End:
